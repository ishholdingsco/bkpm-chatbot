# Copy to .env.local and fill in your own values.

# DeepSeek API (OpenAI-compatible). Server-side only.
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-v4-flash

# Mapbox public access token (starts with pk.). Exposed to the browser.
NEXT_PUBLIC_MAPBOX_TOKEN=

# Public site URL for absolute social/SEO metadata (Open Graph image, canonical).
# Optional: on Vercel it falls back to VERCEL_PROJECT_PRODUCTION_URL automatically;
# locally it falls back to http://localhost:3000. Set to override (e.g. a custom
# domain). Example: https://wilaya-chatbotai.vercel.app
NEXT_PUBLIC_SITE_URL=
